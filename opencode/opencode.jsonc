{
 "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "system",
  "autoupdate": true,
  "keybinds": {},
  "mcp": {
    "ado": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@azure-devops/mcp@next", "HC-MFD"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
